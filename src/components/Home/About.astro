---
import { Image } from "astro:assets";
import Container from "../Container.astro";
import { Accomadation, BarImage, DineImage, EventsImage } from "../../assets/home";
---

<script lang="ts"></script>

<Container>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 py-20">
        <div class="md:col-span-2 flex flex-col gap-6">
            <Image
                src={Accomadation}
                alt="Accommodations"
                class="w-full md:h-[439px] h-[200px] bg-gray-200 rounded-2xl object-cover"
            />
            <div>
                <p
                    class="text-xs uppercase tracking-widest text-[#1A1C1B] mb-2 mt-5"
                >
                    The Accommodations
                </p>
                <h2
                    class="text-4xl font-serif heading-italic text-primary mb-2"
                >
                    Elegance in Every Detail
                </h2>
                <p class="text-[#404943] text-sm max-w-md">
                    Masterfully designed residences featuring bespoke
                    furnishings, premium amenities, and panoramic city views.
                </p>
            </div>
        </div>

        <div
            class="bg-[#0a3d31] md:h-[525px] h-auto rounded-2xl text-white flex flex-col items-center justify-center gap-6"
        >
            <div class="p-8">
                <div class="mb-4">✨</div>
                <h2 class="text-2xl font-serif font-bold mb-2">
                    Events Redefined
                </h2>
                <p
                    class="text-sm opacity-90 leading-relaxed mb-4 text-[#7AB598]"
                >
                    A world-class venue for weddings, galas, and corporate
                    events, where every detail is tailored for perfection.
                </p>
                <Image
                    src={EventsImage}
                    alt="Events"
                    class="w-full bg-gray-700 rounded-b-2xl object-contain"
                />
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:h-[663px]">
        <div class="md:col-span-1 flex flex-col justify-end gap-2">
            <p class="text-xs uppercase tracking-widest text-[#1A1C1B]">
                Culinary Artistry
            </p>
            <h2 class="text-3xl font-bold heading-italic text-primary">
                A Symphony of Flavors
            </h2>
            <p class="text-[#404943] max-w-sm text-sm">
                A forthcoming dining destination featuring global inspirations
                and artisanal, locally sourced ingredients.
            </p>

            <div class="relative w-full h-[383px] mt-7">
                <Image
                    src={DineImage}
                    alt="Culinary"
                    class="w-full h-full bg-gray-200 rounded-2xl object-cover"
                />
                <button
                    class="absolute bottom-6 left-6 bg-primary text-white px-6 py-3 rounded-sm text-sm hover:bg-primary/80 transition"
                >
                    EXPLORE OUR DINING
                </button>
            </div>
        </div>

        <div
            class="md:col-span-2 flex flex-col-reverse md:flex-row gap-8 bg-gray-100 rounded-2xl overflow-hidden"
        >
            <div class="p-8 flex flex-col justify-center gap-2 flex-1">
                <p class="text-xs uppercase tracking-widest text-gray-400">
                    Occasions to Remember
                </p>
                <h2 class="text-3xl font-bold heading-italic text-primary">
                    The Bar (Coming Soon)
                </h2>
                <p class="text-gray-600">
                    An exclusive, sophisticated lounge offering signature
                    cocktails and a curated selection of premium spirits.
                </p>
                <button
                    class="mt-4 px-4 py-2 w-fit text-primary bg-trasparent text-[12px]
border border-[#002F1F]/10
rounded-sm
hover:bg-white/20
transition duration-300"
                >
                    STAY TUNED
                </button>
            </div>
            <Image
                src={BarImage}
                alt="The Bar"
                class="w-full md:w-1/2 bg-gray-300 object-cover"
            />
        </div>
    </div>
</Container>
