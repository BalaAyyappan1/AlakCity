---
import { Image } from 'astro:assets';
import Container from './Container.astro';
import { Room1, Room2, Room3 } from '../assets/rooms';
import { Hall1, Hall2, Hall3, Lounge1, Lounge2, Facility1, Facility2, Facility3 } from '../assets/Gallery';

const galleryItems = [
  // ROOMS
  { title: "Grand Suite", category: "rooms", src: Room1, span: "md:col-span-2 md:row-span-2" },
  { title: "Lounge Area", category: "rooms", src: Room2, span: "md:col-span-1 md:row-span-1" },
  { title: "Quiet Corner", category: "rooms", src: Room3, span: "md:col-span-1 md:row-span-1" },
  
  // HALLS
  { title: "Ballroom A", category: "halls", src: Hall1, span: "md:col-span-1 md:row-span-1" },
  { title: "Reception Hall", category: "halls", src: Hall2, span: "md:col-span-2 md:row-span-2" },
  { title: "Banquet Area", category: "halls", src: Hall3, span: "md:col-span-1 md:row-span-1" },

  // LOUNGE
  { title: "Sky Lounge", category: "lounge", src: Lounge1, span: "md:col-span-2 md:row-span-1" },
  { title: "Garden Lounge", category: "lounge", src: Lounge2, span: "md:col-span-1 md:row-span-1" },

  // SANCTUARY (Fixed bento layout)
  { title: "Washroom", category: "facilities", src: Facility1, span: "md:col-span-2 md:row-span-2" },
  { title: "The Suite", category: "facilities", src: Facility2, span: "md:col-span-1 md:row-span-1" },
  { title: "Sanitation", category: "facilities", src: Facility3, span: "md:col-span-1 md:row-span-1" },
];
---

<section class="md:mt-40 mt-30 mb-20">
  <Container>
    <p class="text-xs sm:text-sm uppercase tracking-[0.2em] text-emerald-800 font-medium mb-4">
      VISUAL ANTHOLOGY
    </p>
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 md:gap-10">
      <h2 class="text-3xl sm:text-4xl md:text-7xl font-serif text-emerald-950 max-w-lg leading-[100%]">
        Curated <br /> Sanctuary<br /> in frames
      </h2>
      <p class="text-emerald-900/80 max-w-md text-base sm:text-lg leading-relaxed md:pt-2">
        A narrative of light, texture, and silence. Explore the intentional architecture of our spaces through a lens of quiet luxury.
      </p>
    </div>
  </Container>
</section>

<section class="bg-[#0b2923] py-24 text-[#d0d9d3]">
  <Container>
    
    <div class="flex flex-col md:flex-row md:justify-between md:items-center mb-16 gap-8">
      <div>
        <h2 class="text-4xl md:text-5xl font-serif text-white mb-4">Gallery</h2>
      </div>

      <div class="flex flex-wrap gap-x-6 gap-y-4" id="gallery-filters">
        <button data-filter="all" class="filter-btn active text-sm uppercase tracking-[0.2em] transition-colors duration-300">All Collections</button>
        <button data-filter="rooms" class="filter-btn text-sm uppercase tracking-[0.2em] transition-colors duration-300 text-[#8ea6a1] hover:text-white">Rooms</button>
        <button data-filter="halls" class="filter-btn text-sm uppercase tracking-[0.2em] transition-colors duration-300 text-[#8ea6a1] hover:text-white">Halls</button>
        <button data-filter="lounge" class="filter-btn text-sm uppercase tracking-[0.2em] transition-colors duration-300 text-[#8ea6a1] hover:text-white">Lounge</button>
        <button data-filter="facilities" class="filter-btn text-sm uppercase tracking-[0.2em] transition-colors duration-300 text-[#8ea6a1] hover:text-white">Facilities</button>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[300px] transition-all duration-500" id="gallery-grid">
      {galleryItems.map((item) => (
        <div 
          class={`gallery-item relative overflow-hidden rounded-sm group cursor-pointer ${item.span}`}
          data-category={item.category}
        >
          {item.src ? (
            <Image src={item.src} alt={item.title} loading="lazy" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
          ) : (
            <div class="w-full h-full bg-[#1a3832] flex items-center justify-center text-[#4e6b66] italic">No Image</div>
          )}
          
          <div class="absolute inset-0 bg-black/20 group-hover:bg-black/40 transition-colors duration-500 flex items-end p-6">
            <h3 class="font-serif text-xl text-white opacity-0 group-hover:opacity-100 transition-opacity duration-500">{item.title}</h3>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.gallery-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('active', 'text-white'));
      buttons.forEach(b => b.classList.add('text-[#8ea6a1]'));
      btn.classList.add('active', 'text-white');
      btn.classList.remove('text-[#8ea6a1]');

      const filter = btn.getAttribute('data-filter');

      items.forEach(item => {
        const category = item.getAttribute('data-category');
        if (filter === 'all' || category === filter) {
          item.classList.remove('hidden', 'scale-0', 'opacity-0');
          item.classList.add('block', 'scale-100', 'opacity-100');
        } else {
          item.classList.add('hidden', 'scale-0', 'opacity-0');
          item.classList.remove('block', 'scale-100', 'opacity-100');
        }
      });
    });
  });
</script>

<style>
  .filter-btn.active {
    color: white;
    border-bottom: 1px solid white;
    padding-bottom: 4px;
  }
  .gallery-item {
    transition: all 0.5s ease-in-out;
  }
</style>