---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/services", label: "Services" },
  { href: "/rooms", label: "Rooms" },
  { href: "/gallery", label: "Gallery" },
  // { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
---
<nav class="fixed top-0 left-0 w-full z-50 bg-white">
  <div class="px-5 lg:px-20">

    <div class="flex items-center justify-between h-20">

      <!-- Left: Logo -->
      <a href="/" class="text-[29px] heading-italic font-bold tracking-wider text-primary z-50 relative uppercase">
        Alak City
      </a>

      <!-- Center: Nav Links (Desktop) -->
     <ul class="hidden md:flex items-center gap-8">
  {navLinks.map(({ href, label }) => (
    <li>
      <a
  href={href}
  class={`relative text-md uppercase transition ${
    currentPath === href
      ? "text-primary font-semibold after:scale-x-100"
      : "text-[#1A1C1B] hover:text-primary after:scale-x-0"
  } 
  after:content-[''] after:absolute after:left-0 after:-bottom-1 
  after:h-[2px] after:w-full after:bg-current 
  after:origin-left after:transition-transform after:duration-300`}
>
  {label}
</a>
    </li>
  ))}
</ul>

      <!-- Right: Button (Desktop) -->
      <div class="hidden md:block">
        <a
          href="/contact"
          class="border bg-primary text-white text-md px-4 py-2 rounded-lg hover:bg-primary/80 hover:text-black transition"
        >
          Book Now
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="menu-btn"
        class="md:hidden relative z-50 w-10 h-10 flex flex-col items-center justify-center gap-1.5 focus:outline-none"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span class="hamburger-line block w-6 h-0.5 bg-black transition-all duration-300 origin-center"></span>
        <span class="hamburger-line block w-6 h-0.5 bg-black transition-all duration-300 origin-center"></span>
        <span class="hamburger-line block w-6 h-0.5 bg-black transition-all duration-300 origin-ce-center"></span>
      </button>

    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 top-16 bg-white z-40 flex flex-col px-6 pt-6 pb-10 translate-x-full transition-transform duration-300 ease-in-out md:hidden"
  >
    <ul class="flex flex-col gap-1 flex-1">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`flex items-center py-3.5 text-base border-b border-gray-100 transition ${
              currentPath === href
                ? "text-black font-semibold"
                : "text-gray-600 hover:text-black"
            }`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile Book Now -->
    <a
      href="/contact"
      class="mt-6 block text-center bg-black text-white py-3 rounded-xl text-sm font-medium hover:bg-gray-800 transition"
    >
      Book Now
    </a>
  </div>
</nav>


<style>
  #menu-btn.open .hamburger-line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  #menu-btn.open .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #menu-btn.open .hamburger-line:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }
</style>

<script>
  const btn = document.getElementById("menu-btn") as HTMLButtonElement;
  const menu = document.getElementById("mobile-menu") as HTMLDivElement;

  btn.addEventListener("click", () => {
    const isOpen = btn.classList.toggle("open");
    btn.setAttribute("aria-expanded", String(isOpen));

    if (isOpen) {
      menu.classList.remove("translate-x-full");
      document.body.style.overflow = "hidden";
    } else {
      menu.classList.add("translate-x-full");
      document.body.style.overflow = "";
    }
  });

  // Close menu on nav link click
  menu.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      btn.classList.remove("open");
      btn.setAttribute("aria-expanded", "false");
      menu.classList.add("translate-x-full");
      document.body.style.overflow = "";
    });
  });
</script>
