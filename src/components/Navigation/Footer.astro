---
import { Image } from "astro:assets";
import { FooterLogo } from "../../assets/home";
import Container from "../Container.astro";


const year = new Date().getFullYear();
---



<footer class="bg-[#0a0a0a] text-gray-400 pt-16 pb-8 ">
  <Container>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16 items-start">

  <!-- LEFT SIDE -->
  <div class="md:col-span-1 flex flex-col gap-4">
    <div class="w-20">
      <Image 
        src={FooterLogo} 
        alt="Alak City Logo" 
        class="w-full h-auto" 
      />
    </div>

    <p class="text-sm leading-relaxed max-w-[220px] text-gray-400">
      Experience the epitome of comfort, elegance, and curated hospitality.
    </p>
  </div>

  <!-- RIGHT SIDE -->
  <div class="md:col-span-3 grid grid-cols-2 md:grid-cols-3 gap-10">

    <!-- Explore -->
    <div>
      <h4 class="text-white text-xs uppercase tracking-[0.2em] mb-6">Explore</h4>
      <ul class="space-y-3 text-sm text-gray-400">
        <li><a href="/about" class="hover:text-amber-500 transition">About Us</a></li>
        <li><a href="/services" class="hover:text-amber-500 transition">Services</a></li>
        <li><a href="/gallery" class="hover:text-amber-500 transition">Gallery</a></li>
        <li><a href="/rooms" class="hover:text-amber-500 transition">Rooms</a></li>
      </ul>
    </div>

    <!-- Legal -->
    <div>
      <h4 class="text-white text-xs uppercase tracking-[0.2em] mb-6">Legal</h4>
      <ul class="space-y-3 text-sm text-gray-400">
        <li><a href="/terms" class="hover:text-amber-500 transition">Terms of Service</a></li>
        <li><a href="/privacy" class="hover:text-amber-500 transition">Privacy Policy</a></li>
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <h4 class="text-white text-xs uppercase tracking-[0.2em] mb-6">Contact</h4>
      <p class="text-sm text-gray-400 mb-4">hello@alakcity.com</p>
      <div class="flex gap-4 text-sm text-gray-400">
        <a href="#" class="hover:text-amber-500 transition">IG</a>
        <a href="#" class="hover:text-amber-500 transition">FB</a>
        <a href="#" class="hover:text-amber-500 transition">IN</a>
      </div>
    </div>

  </div>
</div>

  <div class="max-w-7xl mx-auto pt-8 border-t border-gray-800 text-center text-[10px] uppercase tracking-widest">
    <p>© {year} Alak City Hotel. All rights reserved.</p>
  </div>
  </Container>
</footer>